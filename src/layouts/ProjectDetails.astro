---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import ClockBoardArt from "@/components/ClockBoardArt";
import { getProjectPath } from "@/utils/getProjectPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import IconGitHub from "@/assets/icons/IconGitHub.svg";
import { SITE } from "@/config";

type Props = {
  project: CollectionEntry<"projects">;
  projects: CollectionEntry<"projects">[];
};

const { project, projects } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  tags,
  githubUrl,
  techStack,
} = project.data;

const { Content } = await render(project);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getProjectPath(project.id, project.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Projects ========== */

const allProjects = projects.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentProjectIndex = allProjects.findIndex(a => a.id === project.id);

const prevProject = currentProjectIndex !== 0 ? allProjects[currentProjectIndex - 1] : null;
const nextProject =
  currentProjectIndex !== allProjects.length ? allProjects[currentProjectIndex + 1] : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>

    {/* Project Links */}
    {
      githubUrl && (
        <div class="my-4 flex flex-wrap gap-4">
          <a
            href={githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-accent hover:underline"
          >
            <IconGitHub class="size-5" />
            <span>View on GitHub</span>
          </a>
        </div>
      )
    }

    {/* Tech Stack */}
    {
      techStack && techStack.length > 0 && (
        <div class="my-4">
          <span class="text-sm font-medium">Tech Stack: </span>
          <span class="text-sm text-foreground/80">
            {techStack.join(" • ")}
          </span>
        </div>
      )
    }

    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      {
        title === "ClockBoard" && (
          <div class="not-prose mb-8 w-full overflow-hidden rounded-lg py-2">
            <div class="flex h-[420px] w-full items-center">
              <ClockBoardArt
                boardColor="#FAFAFA"
                faceColor="#F5F5F5"
                boardPadding="40px 6%"
                style={{ height: "100%", width: "100%" }}
                inverted
                behavior="alive"
                client:visible
              />
            </div>
          </div>
        )
      }
      <Content />
      {
        title === "ClockBoard" && (
          <div class="mt-8">
            <h2>Capabilities</h2>

            <h3>Generative Behaviors</h3>
            <p>
              The default <code>aliveTime()</code> behavior cycles through three moods — drifting between ambient patterns, spinning with stagger effects, and displaying the time whenever the minute changes. Every viewing is different.
            </p>
            <p>
              Other built-in behaviors include <code>concentricDance()</code>, <code>gentleDrift()</code>, <code>clock()</code>, and more.
            </p>

            <div class="not-prose mb-8 w-full overflow-hidden rounded-lg">
              <div class="flex h-[380px] w-full items-center">
                <ClockBoardArt
                  boardColor="linear-gradient(135deg, #3a3a3a, #141414)"
                  faceColor="#222222"
                  boardPadding="40px 6%"
                  style={{ height: "100%", width: "100%" }}
                  handColor="#E8E0DF"
                  behavior="concentricDance"
                  client:visible
                />
              </div>
            </div>

            <h3>Spin Animations</h3>
            <p>
              Clocks can spin with stagger delays, creating wave-like effects that ripple across the board. Hands can spin in the same direction, opposite directions, or split apart. Spin reveals land smoothly on a target pattern.
            </p>
            <div class="not-prose mb-8 w-full overflow-hidden rounded-lg">
              <div class="flex h-[380px] w-full items-center">
                <ClockBoardArt
                  boardPadding="40px 6%"
                  style={{ height: "100%", width: "100%" }}
                  behavior="spinReveal"
                  client:visible
                />
              </div>
            </div>

            <h3>Color</h3>
            <p>
              Fully customizable palette with <code>boardColor</code>, <code>faceColor</code>, and <code>handColor</code>. Board backgrounds support CSS gradients.
            </p>
            <div class="not-prose mb-8 w-full overflow-hidden rounded-lg">
              <div class="flex h-[380px] w-full items-center">
                <ClockBoardArt
                  boardColor="#192329"
                  faceColor="#161D21"
                  handColor="#E3E7E8"
                  boardPadding="40px 6%"
                  style={{ height: "100%", width: "100%" }}
                  behavior="gentleDrift"
                  client:visible
                />
              </div>
            </div>

            <h3>Patterns</h3>
            <p>14 built-in ambient patterns, plus tools to create your own.</p>
            <div class="not-prose mb-8 grid grid-cols-3 gap-1.5">
              {
                [
                  "RADIAL",
                  "CONVERGE",
                  "CHECKERBOARD",
                  "WAVE",
                  "VORTEX",
                  "RINGS",
                  "BLOOM",
                  "CHEVRONS",
                  "WINDMILL",
                ].map(name => (
                  <div class="w-full overflow-hidden rounded-md" style="aspect-ratio: 20/8;">
                    <ClockBoardArt
                      patternName={name}
                      boardPadding="6%"
                      style={{ height: "100%", width: "100%" }}
                      client:visible
                    />
                  </div>
                ))
              }
            </div>

            <h3>Composable</h3>
            <p>
              Build custom behaviors by composing steps declaratively. Mix pattern transitions, spins, spin reveals, holds, and stagger effects freely.
            </p>
            <pre><code>{`import { sequence, uniformPattern, composeTime, stagger, RADIAL } from 'clockboard'

const reveal = sequence([
  { pattern: uniformPattern(0, 180), duration: 3000 },
  { pattern: composeTime(14, 30), spinRevolutions: 2, revolutionDuration: 5000, hold: 5000 },
  { pattern: RADIAL, duration: 5000, stagger: stagger.centerOut(1500) },
])`}</code></pre>

            <div class="not-prose mb-2 w-full overflow-hidden rounded-lg">
              <div class="flex h-[380px] w-full items-center">
                <ClockBoardArt
                  handColor="#FADE84"
                  boardPadding="40px 6%"
                  style={{ height: "100%", width: "100%" }}
                  behavior="counterLoop"
                  client:visible
                />
              </div>
            </div>
          </div>
        )
      }
    </article>

    <hr class="my-8 border-dashed" />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />
    <div class="clear-both"></div>

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Project Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevProject && (
          <a
            href={getProjectPath(prevProject.id, prevProject.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>Previous Project</span>
              <div class="text-sm text-accent/85">{prevProject.title}</div>
            </div>
          </a>
        )
      }
      {
        nextProject && (
          <a
            href={getProjectPath(nextProject.id, nextProject.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>Next Project</span>
              <div class="text-sm text-accent/85">{nextProject.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>

